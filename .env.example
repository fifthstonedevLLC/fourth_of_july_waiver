# Copy this file to ".env" and fill in the values you need.

# Port the app listens on (your reverse proxy forwards the subdomain here).
PORT=3000

# ---- Admin / booth check-in page ----
# Shared password for the volunteer check-in page at /admin (any username works).
# Leave blank to keep the admin page disabled.
ADMIN_PASSWORD=

# ---- Email copies (optional) ----
# Leave these blank to disable emailing. The app works fully without them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# The "From" address shown on emailed copies, e.g. "4th of July <noreply@yourdomain.com>"
MAIL_FROM=
